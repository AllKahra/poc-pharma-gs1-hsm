# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# Sistema
.DS_Store

# Saídas geradas em execução
data/*
dm/*
registry/*

# Mantém a estrutura das pastas no repositório
!data/.gitkeep
!dm/.gitkeep
!registry/.gitkeep

# Nunca ignorar código, configuração e referências
!scripts/
!config/
!reference/
